PORT=3000
HOST=127.0.0.1
DATA_DIR=
ALLOWED_IPS=
TRUST_PROXY=false
ADMIN_USERNAME=admin
ADMIN_PASSWORD=
SESSION_DAYS=7
SESSION_COOKIE_SECURE=false

GNP_EMAIL=
GNP_PASSWORD=
AXA_EMAIL=
AXA_PASSWORD=

LOGIN_URL=https://portalintermediarios.gnp.com.mx/sesion
INICIO_URL=https://portalintermediarios.gnp.com.mx/home/dashboard
CONSULTA_URL=https://portalintermediarios.gnp.com.mx/home/pagina-iframe?tipo=aplicacion&menu=Todos%20los%20ramos%20Consulta
SINIESTROS_URL=https://portalintermediarios.gnp.com.mx/home/pagina-iframe?tipo=aplicacion&menu=Siniestros%20ED%20CP%20GN
AXA_URL=https://portal.axa.com.mx/tramites/tramites/listado
AXA_SINIESTROS_URL=https://cloud.distribuidores.axa.com.mx/group/distribucion/distribucion-gestion/autos

# Optional local override when DATA_DIR is empty. Containers always use DATA_DIR/browser-profile.
# Windows local: msedge. Linux/Railway: leave empty to use Playwright Chromium.
BROWSER_CHANNEL=msedge
PROFILE_DIR=
SINIESTROS_PROFILE_DIR=
AXA_SINIESTROS_PROFILE_DIR=
HEADLESS=false

AUTO_REFRESH_MINUTES=10
MANUAL_LOGIN_TIMEOUT_MINUTES=10
RUN_TIMEOUT_MINUTES=5
PAGE_RECOVERY_ATTEMPTS=3
QUERY_RECOVERY_ATTEMPTS=2
CONSULTA_READY_TIMEOUT_MS=25000
KEEP_SCREENSHOTS=100
MAX_LOG_BYTES=1048576

USE_DIRECT_API=true
DIRECT_QUERY_MAX_PAGES=20
QUERY_DATE_FROM=
QUERY_DATE_TO=month_end

# OpenWA WhatsApp notifications for OT status changes.
# API docs: http://localhost:2785/api/docs
OPENWA_ENABLED=false
OPENWA_BASE_URL=http://localhost:2785/api
OPENWA_API_KEY=
OPENWA_SESSION_ID=my-bot
OPENWA_CHAT_IDS=
OPENWA_MAX_CHANGES=10

TV_ROWS_PER_PAGE=18
TV_PAGE_SECONDS=25
TV_HIDE_TERMINADAS=true
TV_STALE_MINUTES=20
TV_SOUND_ENABLED=false
TV_STATUS_POLL_SECONDS=10
TV_AUTO_SCROLL=true
TV_SCROLL_PIXELS=1
TV_SCROLL_INTERVAL_MS=90
